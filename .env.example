ARENA_MODELS=gpt4o_mini,phi4
ARENA_JUDGE_MODEL=
MODEL_TIMEOUT_SECONDS=45

# Cosmos DB for run persistence
COSMOS_ENDPOINT=https://your-cosmos-account.documents.azure.com:443/
# COSMOS_KEY=your-cosmos-primary-key  # needed only if USE_ENTRA_ID=false
COSMOS_DB=ora-db
COSMOS_CONTAINER=runs

# Azure AI Foundry (Entra ID auth)
USE_ENTRA_ID=true

# Fallback to API key auth (set to false if using Entra ID)
MODEL_GPT4O_MINI_BASE_URL=https://your-foundry-endpoint
MODEL_GPT4O_MINI_API_PATH=/chat/completions
MODEL_GPT4O_MINI_API_VERSION=2024-05-01-preview
MODEL_GPT4O_MINI_MODEL=gpt-4o-mini
MODEL_GPT4O_MINI_AUTH_MODE=entra-id
# MODEL_GPT4O_MINI_API_KEY=  # Not needed with Entra ID

MODEL_PHI4_BASE_URL=https://your-foundry-endpoint
MODEL_PHI4_API_PATH=/chat/completions
MODEL_PHI4_API_VERSION=2024-05-01-preview
MODEL_PHI4_MODEL=phi-4
MODEL_PHI4_AUTH_MODE=entra-id
# MODEL_PHI4_API_KEY=  # Not needed with Entra ID
